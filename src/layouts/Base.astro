---
import '../styles/global.css';
import blocks from '../data/blocks.json';

const shared = blocks.filter(b => b.category === 'shared');
const envSpecific = blocks.filter(b => b.category === 'env-specific');
const base = import.meta.env.BASE_URL;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Marketing Block Library - Nordhealth Therapy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 28 28'><rect width='28' height='28' rx='7' fill='%233559c7'/><text x='50%' y='53%' dominant-baseline='central' text-anchor='middle' fill='white' font-family='system-ui' font-weight='700' font-size='15'>N</text></svg>" />
</head>
<body>
  <header class="site-header">
    <a href={base} class="logo">
      <span class="logo-mark">N</span>
      <span>Block Library</span>
    </a>
    <nav class="header-nav-links">
      <a href={base} class="header-nav-link active">Catalog</a>
      <a href={`${base}/philosophy/`} class="header-nav-link">Philosophy</a>
    </nav>
    <div class="header-search">
      <svg class="search-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="7" cy="7" r="5.5" /><line x1="11" y1="11" x2="15" y2="15" />
      </svg>
      <input type="text" id="search" placeholder="Search blocks..." autocomplete="off" />
      <span class="search-shortcut">/</span>
    </div>
    <div class="header-meta">
      <span class="header-stat"><span class="dot"></span> 30 blocks</span>
      <span class="header-stat">5 envs</span>
      <span class="header-stat">v0.1.40</span>
    </div>
    <div class="header-logo-badge">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Nordhealth">
        <path d="M33.722 39.495a5.076 5.076 0 0 1-3.61-1.486l-.026-.026c-.026-.013-.039-.039-.065-.052L16.428 24.195l2.216-2.215L32.21 35.168l.026.026c.027.014.04.04.066.066.378.378.886.6 1.42.6 1.108 0 2.15-.913 2.15-2.047V14.695c0-1.134-1.03-2.046-2.15-2.046a2.03 2.03 0 0 0-1.394.573l-.04.04-6.411 5.89-2.216-2.216 6.347-6.346c.013-.013.026-.04.052-.052A5.216 5.216 0 0 1 33.722 9c2.815 0 5.239 2.28 5.278 5.095v20.317c-.052 2.815-2.476 5.083-5.278 5.083z" fill="#fff"/>
        <path d="M14.148 9c1.355 0 2.645.521 3.61 1.486l.026.026c.026.013.039.039.065.052l13.723 13.605-2.216 2.216-13.697-13.058-.026-.026c-.026-.014-.039-.04-.065-.066a2.014 2.014 0 0 0-1.42-.6c-1.108 0-2.02.913-2.02 2.047V33.8c0 1.134.899 2.046 2.02 2.046a2.03 2.03 0 0 0 1.394-.573l.04-.04 6.41-5.89 2.216 2.215-6.346 6.347c-.013.013-.026.04-.052.052a5.217 5.217 0 0 1-3.662 1.538c-2.815 0-5.109-2.28-5.148-5.095V14.083C9.052 11.268 11.346 9 14.148 9z" fill="#fff"/>
      </svg>
    </div>
  </header>

  <div class="site-layout">
    <nav class="site-sidebar">
      <div class="sidebar-section-label">Shared Blocks</div>
      <ul class="sidebar-nav">
        {shared.map(b => (
          <li>
            <a href={`#${b.id}`}>
              <span class="nav-num">{String(b.num).padStart(2, '0')}</span>
              {b.title}
            </a>
          </li>
        ))}
      </ul>
      <div class="sidebar-section-label" style="margin-top:12px">Environment-Specific</div>
      <ul class="sidebar-nav">
        {envSpecific.map(b => (
          <li>
            <a href={`#${b.id}`}>
              <span class="nav-num">{String(b.num).padStart(2, '0')}</span>
              {b.title}
              <span class="nav-env">{b.envs[0]}</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="sidebar-section-label" style="margin-top:12px">Views</div>
      <ul class="sidebar-nav">
        <li><a href="#matrix">Environment Matrix</a></li>
      </ul>
    </nav>

    <main class="site-main" id="top">
      <slot />
    </main>
  </div>

  <script is:inline>
    // Search
    const search = document.getElementById('search');
    const entries = document.querySelectorAll('.block-entry');
    const sections = document.querySelectorAll('.section-header');
    const empty = document.getElementById('empty-state');

    search.addEventListener('input', () => {
      const q = search.value.toLowerCase().trim();
      let visible = 0;
      entries.forEach(el => {
        const match = !q ||
          el.dataset.title.toLowerCase().includes(q) ||
          el.dataset.slug.toLowerCase().includes(q) ||
          el.dataset.desc.toLowerCase().includes(q);
        el.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      sections.forEach(el => el.style.display = q ? 'none' : '');
      if (empty) empty.style.display = visible === 0 ? '' : 'none';
    });

    // Keyboard shortcut: / to focus search
    document.addEventListener('keydown', e => {
      if (e.key === '/' && document.activeElement !== search) {
        e.preventDefault();
        search.focus();
      }
      if (e.key === 'Escape') {
        search.value = '';
        search.dispatchEvent(new Event('input'));
        search.blur();
      }
    });

    // Active sidebar link on scroll
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          document.querySelectorAll('.sidebar-nav a').forEach(a => a.classList.remove('active'));
          const link = document.querySelector(`.sidebar-nav a[href="#${entry.target.id}"]`);
          if (link) link.classList.add('active');
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px' });

    document.querySelectorAll('.block-entry').forEach(el => observer.observe(el));
  </script>
</body>
</html>
