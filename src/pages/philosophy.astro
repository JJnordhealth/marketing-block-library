<script is:inline>
  // TOC scroll spy
  const tocLinks = document.querySelectorAll('.wiki-toc a');
  const sections = document.querySelectorAll('.wiki-content section, .wiki-content h3[id]');
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        tocLinks.forEach(a => a.style.color = '');
        const id = entry.target.id;
        const link = document.querySelector(`.wiki-toc a[href="#${id}"]`);
        if (link) link.style.color = 'var(--n-accent)';
      }
    });
  }, { rootMargin: '-80px 0px -60% 0px' });
  sections.forEach(s => { if (s.id) observer.observe(s); });
</script>

